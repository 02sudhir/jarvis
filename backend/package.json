{
  "name": "cricket-analytics-backend",
  "version": "1.0.0",
  "description": "Real-time Cricket Analytics Dashboard Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run",
    "seed": "ts-node src/scripts/seed.ts"
  },
  "keywords": [
    "cricket",
    "analytics",
    "real-time",
    "sports",
    "saas"
  ],
  "author": "Cricket Analytics Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.0.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "pg": "^8.10.0",
    "mongodb": "^5.5.0",
    "redis": "^4.6.5",
    "typeorm": "^0.3.14",
    "mongoose": "^7.0.4",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "express-validator": "^7.0.0",
    "axios": "^1.4.0",
    "nodemailer": "^6.9.1",
    "stripe": "^12.0.0",
    "pino": "^8.13.0",
    "pino-http": "^8.3.1",
    "ioredis": "^5.3.2",
    "bull": "^4.10.4",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8",
    "nodemon": "^2.0.22",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2"
  }
}
